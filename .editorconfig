# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 2
tab_width = 2
trim_trailing_whitespace = true

ij_css_use_double_quotes = true
ij_scss_use_double_quotes = true
ij_html_quote_style = double
ij_javascript_use_double_quotes = true
ij_javascript_force_quote_style = true
ij_typescript_use_double_quotes = true
ij_typescript_force_quote_style = true
ij_javascript_use_semicolon_after_statement = true
ij_javascript_force_semicolon_style = true
ij_typescript_use_semicolon_after_statement = true
ij_typescript_force_semicolon_style = true
ij_any_do_while_brace_force = always
ij_any_for_brace_force = always
ij_any_if_brace_force = always
ij_any_else_brace_force = always
ij_any_while_brace_force = always
ij_any_switch_brace_force = always
ij_any_try_brace_force = always
ij_any_catch_brace_force = always
ij_any_finally_brace_force = always
ij_any_for_paren_force = always
ij_any_if_paren_force = always
ij_any_while_paren_force = always
